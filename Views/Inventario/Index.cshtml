@model IEnumerable<IPC2_Practica3_202303088.Models.Producto>

<div class="card shadow">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0 text-primary">Gestión de Inventario</h4>
        <a href="/Inventario/Formulario" class="btn btn-primary">Agregar Producto</a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Categoría</th>
                        <th>Precio</th>
                        <th>Stock</th>
                        <th>Vencimiento</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.GetId()</td>
                                <td><strong>@item.GetNombre()</strong></td>
                                <td>@item.GetDescripcion()</td>
                                <td><span>@item.GetCategoria()</span></td>
                                <td>Q @(item.GetPrecio().ToString("F2"))</td>
                                <td>
                                    <span>@item.GetCantidadStock()</span>
                                </td>
                                <td>@(item.GetFechaVencimiento()?.ToString("dd/MM/yyyy") ?? "N/A")</td>
                                <td>
                                    <div class="btn-group">
                                        <a href="/Inventario/Modificar/@item.GetId()" class="btn btn-warning btn-sm">Modificar</a>
                                        <form action="/Inventario/Eliminar" method="post" style="display:inline;" onsubmit="return confirm('¿Estás seguro de que deseas eliminar este producto?');">
                                            <input type="hidden" name="id" value="@item.GetId()" />
                                            <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted">No hay productos cargados aun...</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>