@model IEnumerable<IPC2_Practica3_202303088.Models.Producto>

<div class="card shadow">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0 text-primary">Gestión de Inventario</h4>
        <a href="/Inventario/Formulario" class="btn btn-primary btn-sm">Agregar Producto</a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Categoría</th>
                        <th>Precio</th>
                        <th>Stock</th>
                        <th>Vencimiento</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.GetId()</td>
                                <td>**@item.GetNombre()**</td>
                                <td><small>@item.GetDescripcion()</small></td>
                                <td><span class="badge bg-info text-dark">@item.GetCategoria()</span></td>
                                <td>Q@item.GetPrecio().ToString("F2")</td>
                                <td>
                                    <span class="badge @(item.GetCantidadStock() <= 5 ? "bg-danger" : "bg-success")">
                                        @item.GetCantidadStock()
                                    </span>
                                </td>
                                <td>@(item.GetFechaVencimiento()?.ToString("dd/MM/yyyy") ?? "N/A")</td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a href="/Inventario/Modificar/@item.GetId()" class="btn btn-warning btn-sm">
                                            Modificar
                                        </a>
                                        <button onclick="eliminarProducto(@item.GetId())" class="btn btn-danger btn-sm">
                                            Eliminar
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                No hay productos registrados en el inventario.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    function eliminarProducto(id) {
        if (confirm('¿Estás seguro de que deseas eliminar este producto?')) {
            console.log("Eliminando producto: " + id);
        }
    }
</script>