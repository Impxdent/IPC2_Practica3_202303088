@model IPC2_Practica3_202303088.Models.Producto

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0">Modificar Producto</h5>
                </div>
                <div class="card-body">
                    <form action="/Inventario/Guardar" method="post">
                        <input type="hidden" name="id" value="@Model.GetId()" />
                        <div class="mb-3">
                            <label class="form-label font-weight-bold">Nombre del Producto</label>
                            <input type="text" name="nombre" class="form-control" value="@Model.GetNombre()" required>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label font-weight-bold">Categoría</label>
                                <input type="text" name="categoria" class="form-control" value="@Model.GetCategoria()" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label font-weight-bold">Precio</label>
                                <input type="number" name="precio" step="0.01" class="form-control" 
                                       value="@Model.GetPrecio().ToString("F2", System.Globalization.CultureInfo.InvariantCulture)" required>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label font-weight-bold">Cantidad en Stock</label>
                                <input type="number" name="cantidadStock" class="form-control" value="@Model.GetCantidadStock()" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label font-weight-bold">Fecha de Vencimiento</label>
                                <input type="date" name="fechaVencimiento" class="form-control" 
                                       value="@(Model.GetFechaVencimiento()?.ToString("yyyy-MM-dd"))">
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label font-weight-bold">Descripción</label>
                            <textarea name="descripcion" class="form-control" rows="3">@Model.GetDescripcion()</textarea>
                        </div>

                        <div class="d-flex justify-content-end gap-2 border-top pt-3">
                            <a href="/Inventario/Index" class="btn btn-outline-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-warning">Actualizar Cambios</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>